# ============================================================
# Webhook 通知服务配置文件
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 编辑 .env，填入你需要的平台的 Webhook 地址/Token
#   3. 不需要的平台保持空白即可，不会影响其他平台
# ============================================================

# ------------------------------------------------------------
# 飞书（Feishu/Lark）机器人
# 获取方式: 群设置 → 群机器人 → 添加机器人 → 自定义机器人
# 文档: https://open.feishu.cn/document/client-docs/bot-5/add-custom-bot
# ------------------------------------------------------------
FEISHU_WEBHOOK_URL=

# ------------------------------------------------------------
# 钉钉自定义机器人
# 获取方式: 群设置 → 智能群助手 → 添加机器人 → 自定义
# 文档: https://open.dingtalk.com/document/robots/custom-robot-access
# ------------------------------------------------------------
DINGTALK_WEBHOOK_URL=
# 若机器人开启了「加签」安全设置，填入签名密钥（以 SEC 开头）
DINGTALK_SECRET=

# ------------------------------------------------------------
# 企业微信群机器人
# 获取方式: 群设置 → 添加群机器人 → 新创建一个机器人
# 文档: https://developer.work.weixin.qq.com/document/path/91770
# ------------------------------------------------------------
WECOM_WEBHOOK_URL=

# ------------------------------------------------------------
# Telegram Bot
# 获取方式: 向 @BotFather 发送 /newbot 命令
# Chat ID 获取: 向 @userinfobot 发消息获取你的 Chat ID
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Slack Incoming Webhook
# 获取方式: https://api.slack.com/apps → 创建 App → Incoming Webhooks
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ------------------------------------------------------------
# Discord Webhook
# 获取方式: 频道设置 → 整合 → Webhooks → 新的 Webhook
# ------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# ------------------------------------------------------------
# Server酱（方糖）- 推送到微信
# 获取方式: 注册 https://sct.ftqq.com 后在「Key & API」页面获取 SendKey
# ------------------------------------------------------------
SERVERCHAN_SENDKEY=
